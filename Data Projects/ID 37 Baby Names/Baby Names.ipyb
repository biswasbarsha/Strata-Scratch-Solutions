middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>c1980</th>\n      <th>clast</th>\n      <th>pct_change</th>\n    </tr>\n    <tr>\n      <th>Name</th>\n      <th></th>\n      <th></th>\n      <th></th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>Mateo</th>\n      <td>6.0</td>\n      <td>9100</td>\n      <td>1515.666667</td>\n    </tr>\n  </tbody>\n</table>\n</div>"},"metadata":{}}],"execution_count":21},{"cell_type":"code","source":"top_decrease = growth.sort_values(\"pct_change\", ascending=True).head(1)\ntop_decrease","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:12:18.787616Z","iopub.execute_input":"2026-03-18T15:12:18.787866Z","iopub.status.idle":"2026-03-18T15:12:18.798511Z","shell.execute_reply.started":"2026-03-18T15:12:18.787848Z","shell.execute_reply":"2026-03-18T15:12:18.797816Z"}},"outputs":[{"execution_count":22,"output_type":"execute_result","data":{"text/plain":"       c1980  clast  pct_change\nName                           \nJill  4555.0      5   -0.998902","text/html":"<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>c1980</th>\n      <th>clast</th>\n      <th>pct_change</th>\n    </tr>\n    <tr>\n      <th>Name</th>\n      <th></th>\n      <th></th>\n      <th></th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>Jill</th>\n      <td>4555.0</td>\n      <td>5</td>\n      <td>-0.998902</td>\n    </tr>\n  </tbody>\n</table>\n</div>"},"metadata":{}}],"execution_count":22},{"cell_type":"markdown","source":"# Question 4: Can you identify names that may have had an even larger increase or decrease in popularity?","metadata":{}},{"cell_type":"code","source":"yearly = final_df.groupby(['Name', 'Year'])['Count'].sum().reset_index()\n\nfirst_last = yearly.groupby('Name').agg(\n    first_year = ('Year', 'min'),\n    last_year = ('Year', 'max')\n).reset_index()\n\nfirst_counts = yearly.merge(first_last[[\"Name\", \"first_year\"]], \n                            left_on=[\"Name\", \"Year\"], \n                            right_on=[\"Name\", \"first_year\"]) \\\n                     .groupby(\"Name\")[\"Count\"].first()\n\nlast_counts = yearly.merge(first_last[[\"Name\", \"last_year\"]], \n                           left_on=[\"Name\", \"Year\"], \n                           right_on=[\"Name\", \"last_year\"]) \\\n                    .groupby(\"Name\")[\"Count\"].first()\n\ntrend = pd.DataFrame({\n    \"first\": first_counts,\n    \"last\": last_counts\n})\n\ntrend[\"net_change\"] = trend[\"last\"] - trend[\"first\"]\n\ntrend[\"abs_change\"] = trend[\"net_change\"].abs()\n\ntrend[\"pct_change\"] = trend[\"net_change\"] / trend[\"first\"].replace(0, pd.NA)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:57:07.782857Z","iopub.execute_input":"2026-03-18T15:57:07.783088Z","iopub.status.idle":"2026-03-18T15:57:08.949397Z","shell.execute_reply.started":"2026-03-18T15:57:07.783068Z","shell.execute_reply":"2026-03-18T15:57:08.948743Z"}},"outputs":[],"execution_count":24},{"cell_type":"code","source":"increase_top = trend.sort_values(\"net_change\", ascending=False).head(10)\nincrease_top","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:57:12.822206Z","iopub.execute_input":"2026-03-18T15:57:12.822448Z","iopub.status.idle":"2026-03-18T15:57:12.836574Z","shell.execute_reply.started":"2026-03-18T15:57:12.822428Z","shell.execute_reply":"2026-03-18T15:57:12.835620Z"}},"outputs":[{"execution_count":25,"