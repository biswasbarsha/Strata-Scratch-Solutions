{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":15254811,"datasetId":9758996,"databundleVersionId":16153246}],"dockerImageVersionId":31286,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# This Python 3 environment comes with many helpful analytics libraries installed\n# It is defined by the kaggle/python Docker image: https://github.com/kaggle/docker-python\n# For example, here's several helpful packages to load\n\nimport numpy as np # linear algebra\nimport pandas as pd # data processing, CSV file I/O (e.g. pd.read_csv)\n\n# Input data files are available in the read-only \"../input/\" directory\n# For example, running this (by clicking run or pressing Shift+Enter) will list all files under the input directory\n\nimport os\nfor dirname, _, filenames in os.walk('/kaggle/input'):\n    for filename in filenames:\n        print(os.path.join(dirname, filename))\n\n# You can write up to 20GB to the current directory (/kaggle/working/) that gets preserved as output when you create a version using \"Save & Run All\" \n# You can also write temporary files to /kaggle/temp/, but they won't be saved outside of the current session","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:01:42.538953Z","iopub.execute_input":"2026-03-18T15:01:42.539763Z","iopub.status.idle":"2026-03-18T15:01:42.934839Z","shell.execute_reply.started":"2026-03-18T15:01:42.539736Z","shell.execute_reply":"2026-03-18T15:01:42.934104Z"}},"outputs":[{"name":"stdout","text":"/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/VA.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/AZ.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/LA.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/CO.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/MO.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/CT.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/NM.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/ID.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/AL.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/GA.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/MS.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/NY.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/DE.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/WI.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/MD.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/RI.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/WY.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/AR.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/MA.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/TN.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/MI.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/UT.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/SC.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/NH.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/WV.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/OH.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/KY.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/ND.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/OK.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/NE.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/HI.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/MN.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/NJ.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/KS.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/DC.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/IN.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/NC.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/VT.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/SD.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/NV.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/FL.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/WA.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/MT.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/OR.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/PA.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/AK.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/IA.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/ME.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/TX.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/IL.TXT\n/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/CA.TXT\n","output_type":"stream"}],"execution_count":2},{"cell_type":"markdown","source":"# Assignment\n## A) Descriptive analysis\n\nPlease describe the format of the data files. \n1. Can you identify any limitations or distortions of the data?\n2. What is the most popular name of all time? (Of either gender.)\n3. What is the most gender ambiguous name in 2013? 1945?\n4. Of the names represented in the data, find the name that has had the largest percentage increase in popularity since 1980. Largest decrease?\n5. Can you identify names that may have had an even larger increase or decrease in popularity?\n\n\n## B) Onward to Insight!\n\nWhat insight can you extract from this dataset? Feel free to combine the baby names data with other publicly available datasets or APIs, but be sure to include code for accessing any alternative data that you use.\n\nThis is an open­ended question and you are free to answer as you see fit. In fact, we would love it if you find an interesting way to look at the data that we haven't thought of!\n\nPlease provide us with both your code and an informative write­up of your results. The code should be in a runnable form. Do not assume that we have a copy of the data set or that we are familiar with the build procedures for your chosen language.","metadata":{}},{"cell_type":"code","source":"import pandas as pd\nimport glob\nimport os\n\n# 1. Define the path pattern\npath = '/kaggle/input/datasets/biswasbarsha/baby-names-dataset/datasets/*.TXT'\n\n# 2. Get a list of all matching file paths\nall_files = glob.glob(path)\n\n# 3. Use a list comprehension to read each file\n# Note: SSN baby name files usually need column names added manually\ncolumn_names = ['State', 'Gender', 'Year', 'Name', 'Count']\n\ndf_list = [pd.read_csv(filename, names=column_names) for filename in all_files]\n\n# 4. Concatenate all DataFrames into one\nfinal_df = pd.concat(df_list, ignore_index=True)\n\nprint(f\"Loaded {len(all_files)} files.\")\nprint(final_df.head())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:01:42.936450Z","iopub.execute_input":"2026-03-18T15:01:42.936931Z","iopub.status.idle":"2026-03-18T15:01:46.412960Z","shell.execute_reply.started":"2026-03-18T15:01:42.936905Z","shell.execute_reply":"2026-03-18T15:01:46.412135Z"}},"outputs":[{"name":"stdout","text":"Loaded 51 files.\n  State Gender  Year       Name  Count\n0    VA      F  1910       Mary    848\n1    VA      F  1910   Virginia    270\n2    VA      F  1910  Elizabeth    254\n3    VA      F  1910       Ruth    218\n4    VA      F  1910   Margaret    209\n","output_type":"stream"}],"execution_count":3},{"cell_type":"code","source":"# Check for Null values\nfinal_df.isnull().sum()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:01:46.413756Z","iopub.execute_input":"2026-03-18T15:01:46.413936Z","iopub.status.idle":"2026-03-18T15:01:47.080953Z","shell.execute_reply.started":"2026-03-18T15:01:46.413919Z","shell.execute_reply":"2026-03-18T15:01:47.079965Z"}},"outputs":[{"execution_count":4,"output_type":"execute_result","data":{"text/plain":"State     0\nGender    0\nYear      0\nName      0\nCount     0\ndtype: int64"},"metadata":{}}],"execution_count":4},{"cell_type":"code","source":"print(\"No. of rows and columns: \",final_df.shape)\nprint(\"Columns Specification: \\n\", final_df.info())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:01:47.083000Z","iopub.execute_input":"2026-03-18T15:01:47.083262Z","iopub.status.idle":"2026-03-18T15:01:47.126433Z","shell.execute_reply.started":"2026-03-18T15:01:47.083239Z","shell.execute_reply":"2026-03-18T15:01:47.125843Z"}},"outputs":[{"name":"stdout","text":"No. of rows and columns:  (6311504, 5)\n<class 'pandas.core.frame.DataFrame'>\nRangeIndex: 6311504 entries, 0 to 6311503\nData columns (total 5 columns):\n #   Column  Dtype \n---  ------  ----- \n 0   State   object\n 1   Gender  object\n 2   Year    int64 \n 3   Name    object\n 4   Count   int64 \ndtypes: int64(2), object(3)\nmemory usage: 240.8+ MB\nColumns Specification: \n None\n","output_type":"stream"}],"execution_count":5},{"cell_type":"code","source":"# Check the unique values\nfor col in final_df.columns:\n    print(f\"Unique values in column '{col}':\")\n    print(final_df[col].unique())\n    print(len(final_df[col].unique()))\n    print(\"-\" * 20)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:01:47.127301Z","iopub.execute_input":"2026-03-18T15:01:47.128112Z","iopub.status.idle":"2026-03-18T15:01:48.772414Z","shell.execute_reply.started":"2026-03-18T15:01:47.128048Z","shell.execute_reply":"2026-03-18T15:01:48.771504Z"}},"outputs":[{"name":"stdout","text":"Unique values in column 'State':\n['VA' 'AZ' 'LA' 'CO' 'MO' 'CT' 'NM' 'ID' 'AL' 'GA' 'MS' 'NY' 'DE' 'WI'\n 'MD' 'RI' 'WY' 'AR' 'MA' 'TN' 'MI' 'UT' 'SC' 'NH' 'WV' 'OH' 'KY' 'ND'\n 'OK' 'NE' 'HI' 'MN' 'NJ' 'KS' 'DC' 'IN' 'NC' 'VT' 'SD' 'NV' 'FL' 'WA'\n 'MT' 'OR' 'PA' 'AK' 'IA' 'ME' 'TX' 'IL' 'CA']\n51\n--------------------\nUnique values in column 'Gender':\n['F' 'M']\n2\n--------------------\nUnique values in column 'Year':\n[1910 1911 1912 1913 1914 1915 1916 1917 1918 1919 1920 1921 1922 1923\n 1924 1925 1926 1927 1928 1929 1930 1931 1932 1933 1934 1935 1936 1937\n 1938 1939 1940 1941 1942 1943 1944 1945 1946 1947 1948 1949 1950 1951\n 1952 1953 1954 1955 1956 1957 1958 1959 1960 1961 1962 1963 1964 1965\n 1966 1967 1968 1969 1970 1971 1972 1973 1974 1975 1976 1977 1978 1979\n 1980 1981 1982 1983 1984 1985 1986 1987 1988 1989 1990 1991 1992 1993\n 1994 1995 1996 1997 1998 1999 2000 2001 2002 2003 2004 2005 2006 2007\n 2008 2009 2010 2011 2012 2013 2014 2015 2016 2017 2018 2019 2020 2021]\n112\n--------------------\nUnique values in column 'Name':\n['Mary' 'Virginia' 'Elizabeth' ... 'Vyan' 'Zylo' 'Zyrus']\n32403\n--------------------\nUnique values in column 'Count':\n[ 848  270  254 ... 2528 2861 2871]\n4938\n--------------------\n","output_type":"stream"}],"execution_count":6},{"cell_type":"markdown","source":"# A) Descriptive analysis\n\n## Question 1: Can you identify any limitations or distortions of the data?\n","metadata":{}},{"cell_type":"code","source":"print(\"-\" * 30)\nprint(\"DATASET SUMMARY & DISTORTION ANALYSIS\")\nprint(\"-\" * 30)\n\n# Basic Counts\nprint(f\"Total Record Counts: {final_df.shape}\")\nprint(f\"Number of Unique Names: {final_df['Name'].nunique()}\")\nprint(f\"Number of Unique States: {final_df['State'].nunique()}\")\n\n# Year Range\nmin_year = final_df['Year'].min()\nmax_year = final_df['Year'].max()\nprint(f'Date Range: {min_year} - {max_year} ({max_year-min_year})')\n\n# Count Value Check (Identifying Limitations)\n# Analyzing the minimum count is crucial to spot privacy cut-offs.\nmin_count = final_df['Count'].min()\nmax_count = final_df['Count'].max()\nprint(f\"Minimum Name Count: {min_count}\")\nprint(f\"Maximum Name Count: {max_count}\")\n\n# Missing Value Check\nmissing_values = final_df.isnull().sum().sum()\nprint(f\"Total Missing Values (Null/NaN): {missing_values}\")\n\nprint(\"-\" * 30)\nprint(\"DISTRIBUTION METRICS (DISTORTIONS)\")\n\n# State Distribution (Is the data biased?)\nprint(\"\\nTop 5 States with Most Records:\")\nprint(final_df['State'].value_counts().head().to_string())\n\n# Year Distribution (Is data volume consistent?)\n# Comparing earliest vs latest years shows how data collection grew over time.\nyear_counts = final_df['Year'].value_counts().sort_index()\nprint(\"\\nEarliest 5 Years (Record Counts):\")\nprint(year_counts.head().to_string())\nprint(\"\\nLatest 5 Years (Record Counts):\")\nprint(year_counts.tail().to_string())\n\n# Skewness\n# High skewness confirms most names are rare (long tail).\nskew_val = final_df['Count'].skew()\nprint('\\nDistribution Skewness (Count): {skew_val:.2f}')\n\n# Interpretation of Skewness\nif skew_val > 1:\n    print(\"-> INTERPRETATION: High positive skew (>1).\")\n    print(\"   This confirms a 'long tail' distribution: Most names are rare (low counts),\")\n    print(\"   while only a small fraction of names are extremely popular.\")\nelif skew_val < -1:\n    print(\"-> INTERPRETATION: High negative skew (<-1).\")\n    print(\"   Most values are high, with a tail of low values.\")\nelse:\n    print(\"-> INTERPRETATION: The distribution is relatively symmetric (between -1 and 1).\")\n\nprint(\"-\" * 30)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:01:48.773491Z","iopub.execute_input":"2026-03-18T15:01:48.773749Z","iopub.status.idle":"2026-03-18T15:01:50.330175Z","shell.execute_reply.started":"2026-03-18T15:01:48.773729Z","shell.execute_reply":"2026-03-18T15:01:50.328812Z"}},"outputs":[{"name":"stdout","text":"------------------------------\nDATASET SUMMARY & DISTORTION ANALYSIS\n------------------------------\nTotal Record Counts: (6311504, 5)\nNumber of Unique Names: 32403\nNumber of Unique States: 51\nDate Range: 1910 - 2021 (111)\nMinimum Name Count: 5\nMaximum Name Count: 10026\nTotal Missing Values (Null/NaN): 0\n------------------------------\nDISTRIBUTION METRICS (DISTORTIONS)\n\nTop 5 States with Most Records:\nState\nCA    400762\nTX    368987\nNY    309532\nIL    237839\nFL    218192\n\nEarliest 5 Years (Record Counts):\nYear\n1910    16829\n1911    17621\n1912    23179\n1913    25276\n1914    28822\n\nLatest 5 Years (Record Counts):\nYear\n2017    94477\n2018    94111\n2019    94090\n2020    92909\n2021    94674\n\nDistribution Skewness (Count): {skew_val:.2f}\n-> INTERPRETATION: High positive skew (>1).\n   This confirms a 'long tail' distribution: Most names are rare (low counts),\n   while only a small fraction of names are extremely popular.\n------------------------------\n","output_type":"stream"}],"execution_count":7},{"cell_type":"markdown","source":"# Question 2: What is the most popular name of all time? (Of either gender.)","metadata":{}},{"cell_type":"code","source":"popular_name = final_df.groupby('Name')['Count'].sum().sort_values(ascending=False).head(1)\npopular_name","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:01:50.331134Z","iopub.execute_input":"2026-03-18T15:01:50.331345Z","iopub.status.idle":"2026-03-18T15:01:50.823432Z","shell.execute_reply.started":"2026-03-18T15:01:50.331327Z","shell.execute_reply":"2026-03-18T15:01:50.822470Z"}},"outputs":[{"execution_count":8,"output_type":"execute_result","data":{"text/plain":"Name\nJames    5054074\nName: Count, dtype: int64"},"metadata":{}}],"execution_count":8},{"cell_type":"code","source":"top5_female = (\n    final_df[final_df['Gender']=='F']\n    .groupby('Name')['Count']\n    .sum()\n    .sort_values(ascending=False)\n    .head()\n)\ntop5_female","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:01:50.824499Z","iopub.execute_input":"2026-03-18T15:01:50.824768Z","iopub.status.idle":"2026-03-18T15:01:51.610867Z","shell.execute_reply.started":"2026-03-18T15:01:50.824741Z","shell.execute_reply":"2026-03-18T15:01:51.610118Z"}},"outputs":[{"execution_count":9,"output_type":"execute_result","data":{"text/plain":"Name\nMary         3747982\nPatricia     1569661\nElizabeth    1560365\nJennifer     1468240\nLinda        1448868\nName: Count, dtype: int64"},"metadata":{}}],"execution_count":9},{"cell_type":"code","source":"top5_male = (\n    final_df[final_df['Gender']=='M']\n    .groupby('Name')['Count']\n    .sum()\n    .sort_values(ascending=False)\n    .head()\n)\ntop5_male","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-18T15:01:51.611729Z","iopub.execute_input":"2026-03-18T15:01:51.611911Z","iopub.status.idle":"2026-03-18T15:01:52.293732Z","shell.execute_reply.started":"2026-03-18T15:01:51.611895Z","shell.execute_reply":"2026-03-18T15:01:52.293053Z"}},"outputs":[{"execution_count":10,"output_type":"execute_result","data":{"text/plain":"Name\nJames      5035762\nJohn       4895305\nRobert     4747986\nMichael    4379257\nWilliam    3929698\nName: Count, dtype: int64"},"metadata":{}}],"execution_count":10},{"cell_type":"code","source":"import matplotlib.pyplot as plt\n\nplt.figure(figsize=(8,6))\nplt.bar(top5_female.index, top5_female.values, color='pink')\nplt.title(\"Top 5 Most Popular Female Names of All Time\")\nplt.ylabel(\"Total Count\")\nplt.xtic