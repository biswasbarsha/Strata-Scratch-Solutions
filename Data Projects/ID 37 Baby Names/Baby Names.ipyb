Z"}},"outputs":[{"execution_count":13,"output_type":"execute_result","data":{"text/plain":"Gender      F      M   diff\nName                       \nNikita     47     47      0\nSonam       5      5      0\nDevine     10     10      0\nCree       11     11      0\nArlin       5      5      0\n...       ...    ...    ...\nDaniel     10  14308  14298\nAva     15259      5  15254\nMason      24  17717  17693\nNoah       31  18269  18238\nEmma    20954      5  20949\n\n[502 rows x 3 columns]","text/html":"<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th>Gender</th>\n      <th>F</th>\n      <th>M</th>\n      <th>diff</th>\n    </tr>\n    <tr>\n      <th>Name</th>\n      <th></th>\n      <th></th>\n      <th></th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>Nikita</th>\n      <td>47</td>\n      <td>47</td>\n      <td>0</td>\n    </tr>\n    <tr>\n      <th>Sonam</th>\n      <td>5</td>\n      <td>5</td>\n      <td>0</td>\n    </tr>\n    <tr>\n      <th>Devine</th>\n      <td>10</td>\n      <td>10</td>\n      <td>0</td>\n    </tr>\n    <tr>\n      <th>Cree</th>\n      <td>11</td>\n      <td>11</td>\n      <td>0</td>\n    </tr>\n    <tr>\n      <th>Arlin</th>\n      <td>5</td>\n      <td>5</td>\n      <td>0</td>\n    </tr>\n    <tr>\n      <th>...</th>\n      <td>...</td>\n      <td>...</td>\n      <td>...</td>\n    </tr>\n    <tr>\n      <th>Daniel</th>\n      <td>10</td>\n      <td>14308</td>\n      <td>14298</td>\n    </tr>\n    <tr>\n      <th>Ava</th>\n      <td>15259</td>\n      <td>5</td>\n      <td>15254</td>\n    </tr>\n    <tr>\n      <th>Mason</th>\n      <td>24</td>\n      <td>17717</td>\n      <td>17693</td>\n    </tr>\n    <tr>\n      <th>Noah</th>\n     